import * as path from 'node:path'
import { createRequire } from 'node:module'
import * as url from 'node:url'
import { promises as fs } from 'node:fs'

const solc: { compile: (input: string) => string } = createRequire(import.meta.url)('solc')
const projectRoot = path.join(path.dirname(url.fileURLToPath(import.meta.url)), '..')
const contractsDirectory = path.join(projectRoot, 'contracts')
const generatedModulePath = path.join(projectRoot, 'app', 'ts', 'generated', 'ethereumByteCodes.ts')

const contracts = [
	{ sourceFile: 'EcRecoverOverride.sol', contractName: 'EcRecoverOverride', exportName: 'ecRecoverOverrideByteCode' },
	{ sourceFile: 'CompoundGovernanceTimeLockMulticall.sol', contractName: 'CompoundGovernanceTimeLockMulticall', exportName: 'compoundGovernanceTimeLockMulticallByteCode' },
	{ sourceFile: 'GetCode.sol', contractName: 'GetCode', exportName: 'getCodeByteCode' },
	{ sourceFile: 'GnosisSafeProxyProxy.sol', contractName: 'GnosisSafeProxyProxy', exportName: 'gnosisSafeProxyProxyByteCode' },
] as const

const sources = Object.fromEntries(await Promise.all(contracts.map(async ({ sourceFile }) => [
	sourceFile,
	{ content: await fs.readFile(path.join(contractsDirectory, sourceFile), 'utf8') },
])))

const compilerInput = {
	language: 'Solidity',
	sources,
	settings: {
		optimizer: { enabled: false },
		metadata: { bytecodeHash: 'none' },
		libraries: { 'GetCode.sol': { GetCode: '0x0000000000000000000000000000000000000000' } },
		outputSelection: { '*': { '*': ['evm.deployedBytecode.object'] } },
	},
}

const compilerOutput = JSON.parse(solc.compile(JSON.stringify(compilerInput)))
const compilerErrors = compilerOutput.errors?.filter((error: { severity: string }) => error.severity === 'error') ?? []
if (compilerErrors.length > 0) {
	throw new Error(`Solidity compilation failed:\n${ compilerErrors.map((error: { formattedMessage: string }) => error.formattedMessage).join('\n') }`)
}

const normalizeByteCode = (byteCode: unknown, sourceFile: string, contractName: string) => {
	if (typeof byteCode !== 'string') throw new Error(`Solidity compiler did not produce deployable bytecode for ${ sourceFile }:${ contractName }`)
	const unprefixedByteCode = byteCode.startsWith('0x') ? byteCode.slice(2) : byteCode
	if (unprefixedByteCode.length === 0 || unprefixedByteCode.length % 2 !== 0 || !/^[0-9a-f]+$/i.test(unprefixedByteCode)) {
		throw new Error(`Solidity compiler did not produce deployable bytecode for ${ sourceFile }:${ contractName }`)
	}
	return `0x${ unprefixedByteCode }`
}

const generatedExports = contracts.map(({ sourceFile, contractName, exportName }) => {
	const byteCode = normalizeByteCode(compilerOutput.contracts?.[sourceFile]?.[contractName]?.evm?.deployedBytecode?.object, sourceFile, contractName)
	return `export const ${ exportName } = '${ byteCode }'\n`
}).join('')

await fs.mkdir(path.dirname(generatedModulePath), { recursive: true })
await fs.writeFile(generatedModulePath, `// Generated by build/compileSolidityContracts.mts. Do not edit.\n${ generatedExports }`)
